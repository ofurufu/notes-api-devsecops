{
  "name": "notes-api-devsecops",
  "version": "1.0.0",
  "description": "Production-grade DevSecOps CI/CD pipeline demo — Notes REST API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "jest --coverage --forceExit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    }
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
